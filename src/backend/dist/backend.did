type HttpResponse = 
 record {
   body: blob;
   headers: vec record {
                  text;
                  text;
                };
   status_code: nat16;
   upgrade: opt bool;
 };
type HttpRequest = 
 record {
   body: blob;
   headers: vec record {
                  text;
                  text;
                };
   method: text;
   url: text;
 };
service : {
  http_request: (req: HttpRequest) -> (HttpResponse) query;
  http_request_update: (req: HttpRequest) -> (HttpResponse);
}
